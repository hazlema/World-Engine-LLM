###########################################################
## Too use images and narration set a google api key
## https://aistudio.google.com/app/api-keys
###########################################################
## GEMINI_API_KEY=

###########################################################
## Local OpenAI-compatible endpoint (LM Studio by default).
## Override if your LM Studio runs on a different port, host,
## or behind auth (include the user:pass@ in the URL).
###########################################################
LM_STUDIO_URL=http://localhost:1234

###########################################################
## Local model id sent to LM Studio for the narrator, archivist,
## and interpreter passes. Each id must match what LM Studio reports
## at /v1/models. See docs/local-narrator-bake-off.md for picks.
##
## LOCAL_MODEL is the default for all three stages. Per-stage
## overrides let you route narrator to a small fast model and
## archivist + interpreter to a larger model that handles
## structured-JSON output reliably.
##
## This is the best local only setup, but yyou will get no
## narration or images without a google api key
##
## YOUR GAMEPLAY MAY SUFFER IF YOU CHANGE THESE!  NOT
## ALL MODELS ARE CREATED EQUAL. GEMMA IS GREAT AT DOING 
## THINGS BUT IS BAD AT STORY TELLING
###########################################################
LOCAL_MODEL=google/gemma-3-12b
LOCAL_NARRATOR_MODEL=mistralai/ministral-3-3b
## Archivist: nvidia/nemotron-3-nano-4b hit 10/10 on the lab testbed
## (lab/local-models, baseline-turn coverage). 4B is plenty for the
## structured-JSON job; gemma-3-12b also passes but is ~3x slower.
LOCAL_ARCHIVIST_MODEL=nvidia/nemotron-3-nano-4b
## Interpreter: nvidia/nemotron-3-nano-4b hit 22/22 on the lab testbed
## (lab/local-models, v3-movement-verbs prompt, deterministic). Fast 4B.
LOCAL_INTERPRETER_MODEL=nvidia/nemotron-3-nano-4b

###########################################################
## Thinking models (Nemotron, Qwen3, etc.): if you use one as
## the narrator, turn thinking OFF at the LM Studio server level
## (Developer tab -> model settings -> Reasoning toggle), NOT
## via an in-prompt directive. Nvidia documents "detailed
## thinking off" as the control phrase but LM Studio's GGUF
## runtime applies the chat template before the model sees the
## prompt, so the in-prompt phrase is ignored.
##
## Symptom of thinking left ON: narrator turns take ~30s instead
## of ~2-8s. Disabling it server-side drops latency immediately.
###########################################################

###########################################################
## Per-stage sampling knobs (defaults shown). Raise narrator
## temp for more creativity, keep archivist temp low for
## reliable JSON, interpreter temp at 0 for deterministic
## classification. top_p left unset = LM Studio default
## kicks in. These pair with the per-stage model routing
## above to give every stage independent character.
###########################################################
## LOCAL_NARRATOR_TEMP=0.95
## LOCAL_ARCHIVIST_TEMP=0.5
## LOCAL_INTERPRETER_TEMP=0
## LOCAL_NARRATOR_TOP_P=0.95
## LOCAL_ARCHIVIST_TOP_P=0.9
## LOCAL_INTERPRETER_TOP_P=1.0

###########################################################
## To override the local server and use Gemini enable
## these. TBH: Quality will increase if enabled.
###########################################################
## NARRATOR_PROVIDER=gemini
## NARRATOR_GEMINI_MODEL=gemini-2.5-flash
## INTERPRETER_PROVIDER=gemini
## INTERPRETER_GEMINI_MODEL=gemini-2.5-flash
