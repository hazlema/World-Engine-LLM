###########################################################
## World Engine — environment configuration
##
## Copy this file to .env and fill in the values you need.
###########################################################

## Required for any stage with provider=local
LM_STUDIO_URL=http://localhost:1234

## Required for any stage with provider=openrouter
## Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

## One line per pipeline stage: provider,model
## provider must be one of: local, openrouter
## model is the exact id sent to that provider
NARRATOR_PROVIDER=openrouter,nvidia/nemotron-3-nano
ARCHIVIST_PROVIDER=local,nvidia/nemotron-3-nano
INTERPRETER_PROVIDER=local,nvidia/nemotron-3-nano

###########################################################
## Optional features
###########################################################

## Run the Python TTS sidecar at startup. Default: true.
## Set USE_NARRATION=false if you haven't installed the sidecar (no Python,
## no GPU, etc.) — the game still works, just without spoken narration.
USE_NARRATION=true

## ElevenLabs cloud TTS — overrides the local Chatterbox sidecar when true.
## When enabled, the Python sidecar is NOT spawned (no GPU/Python needed).
## Get a key at https://elevenlabs.io/app/settings/api-keys
##
## ELEVENLABS_VOICES is "label:voice_id,label:voice_id". The labels show
## up in the narration settings dropdown — rename them to whatever you like.
## Browse voices at https://elevenlabs.io/app/voice-library
##
## ELEVENLABS_MODEL: eleven_flash_v2_5 is the half-price tier with great
## quality. eleven_multilingual_v2 is the higher-cost flagship.
USE_ELEVENLABS=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICES=voice1:kqVT88a5QfII1HNAEPTJ,voice2:z7i51AlFqQJ8JzM16o7e
ELEVENLABS_MODEL=eleven_flash_v2_5

## Gemini API key (required if USE_GEMINI_IMAGES is true)
##
## Required if USE_GEMINI_IMAGES is true (narration uses self-hosted Chatterbox).
## Get a key at https://aistudio.google.com/app/api-keys
###########################################################
GEMINI_API_KEY=

## Per-turn images via Gemini Nano Banana.
USE_GEMINI_IMAGES=false