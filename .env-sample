###########################################################
## Too use images and narration set a google api key
## https://aistudio.google.com/app/api-keys
###########################################################
GEMINI_API_KEY=

###########################################################
## Local OpenAI-compatible endpoint (LM Studio by default).
## Override if your LM Studio runs on a different port, host,
## or behind auth (include the user:pass@ in the URL).
###########################################################
## LM_STUDIO_URL=http://localhost:1234

###########################################################
## Local model id sent to LM Studio for narrator / archivist /
## interpreter. Must match an id LM Studio reports at /v1/models.
## See docs/local-narrator-bake-off.md for recommended choices.
###########################################################
## LOCAL_MODEL=google/gemma-3-12b

###########################################################
## To override the local server and use Gemini enable
## these. TBH: Quality will increase a lot if enabled.
###########################################################
## NARRATOR_PROVIDER=gemini
## NARRATOR_GEMINI_MODEL=gemini-2.5-flash
## INTERPRETER_PROVIDER=gemini
## INTERPRETER_GEMINI_MODEL=gemini-2.5-flash
